# External tools directories (cloned separately, contain nested git repos)
# Large binaries (ffmpeg, nvtt, texconv, etc.) must NOT be committed to Git.
# Use Git LFS (see .gitattributes) if any binary absolutely must live in the repo.
# Download instructions: tools/README.md
tools/*
!tools/README.md

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Build artifacts
*.zip
dist/
build/

# VS Code
.vscode/
*.code-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Blender temp files
*.blend1
*.blend2
