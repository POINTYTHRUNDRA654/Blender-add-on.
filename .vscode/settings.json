{
  // ── Git ──────────────────────────────────────────────────────────────────
  // Always confirm before syncing so accidental pushes of large files are caught.
  "git.confirmSync": true,
  // Keep the local repo up to date automatically.
  "git.autofetch": true,
  "git.autofetchPeriod": 180,
  // Never silently stage-all and commit — require explicit staging.
  "git.enableSmartCommit": false,
  // Show the push/pull button in the status bar.
  "git.showPushSuccessNotification": true,
  // Rebase instead of merge when pulling, matching end_session.bat behaviour.
  // This keeps the commit history linear and avoids spurious merge commits.
  "git.rebaseWhenSync": true,
  // Use the committed hooks in .githooks/ (large-file safety check, etc.).
  // Activate once per clone with: git config core.hooksPath .githooks
  // The "Setup git hooks" task in this workspace does that automatically.
  "git.hooks.enabled": true,

  // ── Files: hide large binaries from the explorer & Source Control panel ──
  // Anything matching .gitignore is already hidden from Source Control, but
  // explicitly listing the most dangerous types here also removes them from
  // the file explorer so they can never be accidentally clicked and staged.
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/*.pyo": true,
    // LLM / GGUF model files (Mossy AI is an external HTTP service — no model
    // file belongs in this repo; these are 2–8 GB each)
    "**/*.gguf": true,
    "**/*.ggml": true,
    "**/*.ggmf": true,
    "**/*.llamafile": true,
    // AI model weight files (can be many GB each)
    "**/*.pt": true,
    "**/*.pth": true,
    "**/*.ckpt": true,
    "**/*.safetensors": true,
    "**/*.onnx": true,
    // Common model/weights directories
    "**/models": true,
    "**/weights": true,
    "**/checkpoints": true,
    // Large media
    "**/*.blend": true,
    "**/*.blend1": true,
    "**/*.blend2": true
  },

  // ── Search: skip the same heavy paths ────────────────────────────────────
  "search.exclude": {
    "**/__pycache__": true,
    "tools/**": true,
    "build_temp/**": true,
    "dist/**": true
  },

  // ── Python ───────────────────────────────────────────────────────────────
  "python.analysis.extraPaths": [],
  "python.languageServer": "Pylance",
  "[python]": {
    "editor.formatOnSave": false,
    "editor.rulers": [120]
  },

  // ── Editor ───────────────────────────────────────────────────────────────
  "editor.trimAutoWhitespace": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── File associations ─────────────────────────────────────────────────────
  "files.associations": {
    "*.toml": "toml",
    "*.bat": "bat"
  }
}
